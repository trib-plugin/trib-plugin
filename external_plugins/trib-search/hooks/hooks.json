{
  "description": "trib-search hooks — deps sync on session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/deps-sync.cjs",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
