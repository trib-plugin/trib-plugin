[
  {
    "name": "reply",
    "title": "Discord Reply",
    "annotations": {
      "title": "Discord Reply",
      "readOnlyHint": false,
      "destructiveHint": false,
      "idempotentHint": false,
      "openWorldHint": true
    },
    "description": "Send a message to a Discord channel. Supports text, reply threading, file attachments, embeds, and components.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "chat_id": {
          "type": "string",
          "description": "Channel ID"
        },
        "text": {
          "type": "string",
          "description": "Message text (markdown)"
        },
        "reply_to": {
          "type": "string",
          "description": "Message ID to thread under"
        },
        "files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Absolute file paths to attach. Max 10, 25MB each."
        },
        "embeds": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Discord embed objects."
        },
        "components": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Discord message components."
        }
      },
      "required": ["chat_id", "text"]
    },
    "module": "channels"
  },
